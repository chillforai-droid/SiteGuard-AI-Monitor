# ============================================
# AI Website Monitor — Environment Variables
# ============================================
# NOTE: For Render deployment, you do NOT need to set any API keys here.
# Users enter their own OpenRouter API key and Monitor API key via the Settings UI.
# These are stored in browser localStorage and sent with each request.

# Server port (Render sets this automatically)
PORT=3001

# Node environment
NODE_ENV=production

# --- OPTIONAL: Server-side overrides ---
# If set, these override any user-provided keys from the browser.
# Leave empty for the default user-managed key flow.

# ANTHROPIC_API_KEY=   # Recommended — users can also set via Settings UI
# OPENROUTER_API_KEY=  # Leave empty — users provide their own
# GITHUB_TOKEN=        # Leave empty — users provide per-website
# MONITOR_API_KEY=     # Leave empty — users set their own password

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the Texly integration.
# Example: https://www.texlyonline.in,https://texlyonline.in
# Leave empty to allow all origins (fine for a public tool).
ALLOWED_ORIGINS=https://www.texlyonline.in,https://texlyonline.in
